{% extends 'base.html.twig' %}

{% block title %}Skin index{% endblock %}

{% block body %}
    <h1>Skin index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>File_name</th>
                <th>Unlocked_skin</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for skin in skins %}
            <tr>
                <td>{{ skin.id }}</td>
                <td>{{ skin.fileName }}</td>
                <td>{{ skin.unlockedSkin ? 'Yes' : 'No' }}</td>
                <td>
                    <a href="{{ path('app_skin_show', {'id': skin.id}) }}">show</a>
                    <a href="{{ path('app_skin_edit', {'id': skin.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_skin_new') }}">Create new</a>
{% endblock %}
