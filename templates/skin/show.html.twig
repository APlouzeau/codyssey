{% extends 'base.html.twig' %}

{% block title %}Skin{% endblock %}

{% block body %}
    <h1>Skin</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ skin.id }}</td>
            </tr>
            <tr>
                <th>File_name</th>
                <td>{{ skin.fileName }}</td>
            </tr>
            <tr>
                <th>Unlocked_skin</th>
                <td>{{ skin.unlockedSkin ? 'Yes' : 'No' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_skin_index') }}">back to list</a>

    <a href="{{ path('app_skin_edit', {'id': skin.id}) }}">edit</a>

    {{ include('skin/_delete_form.html.twig') }}
{% endblock %}
