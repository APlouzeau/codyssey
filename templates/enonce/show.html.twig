{% extends 'base.html.twig' %}

{% block title %}Enonce{% endblock %}

{% block body %}
    <h1>Enonce</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ enonce.id }}</td>
            </tr>
            <tr>
                <th>Title</th>
                <td>{{ enonce.title }}</td>
            </tr>
            <tr>
                <th>Content</th>
                <td>{{ enonce.content }}</td>
            </tr>
            <tr>
                <th>Expected_results</th>
                <td>{{ enonce.expectedResults }}</td>
            </tr>
            <tr>
                <th>Xp_gain</th>
                <td>{{ enonce.xpGain }}</td>
            </tr>
            <tr>
                <th>Life_number</th>
                <td>{{ enonce.lifeNumber }}</td>
            </tr>
            <tr>
                <th>Timer</th>
                <td>{{ enonce.timer ? enonce.timer|date('H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_enonce_index') }}">back to list</a>

    <a href="{{ path('app_enonce_edit', {'id': enonce.id}) }}">edit</a>

    {{ include('enonce/_delete_form.html.twig') }}
{% endblock %}
