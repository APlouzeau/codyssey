{% extends 'base.html.twig' %}

{% block title %}LessonCodePart index{% endblock %}

{% block body %}
    <h1>LessonCodePart index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Content</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for lesson_code_part in lesson_code_parts %}
            <tr>
                <td>{{ lesson_code_part.id }}</td>
                <td>{{ lesson_code_part.content }}</td>
                <td>
                    <a href="{{ path('app_lesson_code_part_show', {'id': lesson_code_part.id}) }}">show</a>
                    <a href="{{ path('app_lesson_code_part_edit', {'id': lesson_code_part.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_lesson_code_part_new') }}">Create new</a>
{% endblock %}
