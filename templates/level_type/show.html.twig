{% extends 'base.html.twig' %}

{% block title %}LevelType{% endblock %}

{% block body %}
    <h1>LevelType</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ level_type.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ level_type.name }}</td>
            </tr>
            <tr>
