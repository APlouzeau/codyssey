# Environment de production pour Codyssey
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=CHANGE_ME_TO_RANDOM_SECRET_KEY

# Base de données PostgreSQL
POSTGRES_VERSION=16
POSTGRES_DB=codyssey_prod
POSTGRES_USER=codyssey
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# URL de la base (utilisée par Symfony)
DATABASE_URL=postgresql://codyssey:CHANGE_ME_SECURE_PASSWORD@database:5432/codyssey_prod?serverVersion=16&charset=utf8

# Mailer (à configurer selon ton SMTP)
MAILER_DSN=smtp://localhost:1025
